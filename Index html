// Navbar scroll effect

window.addEventListener('scroll',()=>{

    const nav = document.getElementById('navbar');

    if(window.scrollY > 70){

        nav.classList.add(
            'shadow-2xl',
            'py-3'
        );

        nav.classList.remove('py-5');

    }else{

        nav.classList.remove(
            'shadow-2xl',
            'py-3'
        );

        nav.classList.add('py-5');
    }

});

