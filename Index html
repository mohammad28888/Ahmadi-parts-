    background:linear-gradient(#f59e0b,#facc15);
    border-radius:20px;
}

/* ========================= */
/* NAVBAR */
/* ========================= */

.nav-glass{
    background:rgba(2,6,23,0.75);
    backdrop-filter:blur(18px);
    border-bottom:1px solid rgba(255,255,255,0.06);
}

/* ========================= */
/* HERO */
/* ========================= */

.hero{
    min-height:100vh;
    position:relative;
    overflow:hidden;
}

.hero::before{
    content:'';
    position:absolute;
    inset:0;
    background:
    linear-gradient(rgba(2,6,23,.82),rgba(2,6,23,.88)),
    url('https://images.unsplash.com/photo-1601584115197-04ecc0da31d7?q=80&w=2070&auto=format&fit=crop');
    background-size:cover;
    background-position:center;
    animation:bgzoom 18s infinite alternate ease-in-out;
}

@keyframes bgzoom{
    from{
        transform:scale(1);
    }
    to{
        transform:scale(1.12);
    }
}

/* ========================= */
/* GLOW */
/* ========================= */

.glow{
    box-shadow:
    0 0 25px rgba(251,191,36,.35),
    0 0 60px rgba(251,191,36,.15);
}

/* ========================= */
/* FLOATING */
/* ========================= */

.float{
    animation:float 4s ease-in-out infinite;
}

@keyframes float{
    0%{
        transform:translateY(0px);
    }
    50%{
        transform:translateY(-15px);
    }
    100%{
        transform:translateY(0px);
    }
}

/* ========================= */
/* TRUCK CARD */
/* ========================= */

.truck-card{
    position:relative;
    overflow:hidden;
    border-radius:30px;
    background:#0f172a;
    transition:.5s;
    border:1px solid rgba(255,255,255,.05);
}

.truck-card:hover{
    transform:translateY(-15px);
    box-shadow:0 25px 50px rgba(0,0,0,.45);
}

.truck-card img{
    transition:1s;
}

.truck-card:hover img{
    transform:scale(1.12);
}

.overlay{
    position:absolute;
    inset:0;
    background:linear-gradient(to top,rgba(2,6,23,.95),transparent);
}

/* ========================= */
/* GOLD BUTTON */
/* ========================= */

.gold-btn{
    background:linear-gradient(135deg,#f59e0b,#facc15);
    color:#000;
    transition:.4s;
}

.gold-btn:hover{
    transform:translateY(-5px) scale(1.04);
    box-shadow:0 20px 35px rgba(250,204,21,.35);
}

/* ========================= */
/* SHINE */
/* ========================= */

.shine{
    position:relative;
    overflow:hidden;
}

.shine::before{
    content:'';
    position:absolute;
    top:0;
    left:-120%;
    width:70%;
    height:100%;
    background:linear-gradient(
        90deg,
        transparent,
        rgba(255,255,255,.25),
        transparent
    );
    transform:skewX(-25deg);
}

.shine:hover::before{
    animation:shine 1s;
}

@keyframes shine{
    100%{
        left:150%;
    }
}

/* ========================= */
/* SECTION */
/* ========================= */

.section-title{
    font-size:clamp(2rem,4vw,4rem);
    font-weight:900;
    line-height:1.2;
